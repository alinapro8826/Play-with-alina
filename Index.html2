<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PLAYWITHALINA PRO - Premium Dollar Gaming</title>
    
    <!-- Direct App Download Link Setup (PWA Manifest) -->
    <link rel="manifest" href="manifest.json">
    
    <style>
        body {
            background-color: #0f0f12;
            color: #ffffff;
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* 1. Premium Neon Gaming Navigation Bar Styling */
        .gaming-navbar {
            background: #14141c;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
            border-bottom: 2px solid #00ff66;
            box-shadow: 0 4px 20px rgba(0, 255, 102, 0.1);
        }
        .nav-logo a {
            color: #fff;
            font-size: 22px;
            font-weight: 900;
            text-decoration: none;
            letter-spacing: 1px;
        }
        .pro-tag {
            background: #00ff66;
            color: #000;
            font-size: 11px;
            padding: 2px 6px;
            border-radius: 4px;
            vertical-align: middle;
            margin-left: 5px;
        }
        .nav-links a {
            color: #aaa;
            text-decoration: none;
            margin: 0 12px;
            font-size: 15px;
            font-weight: 600;
            transition: 0.2s;
        }
        .nav-links a:hover {
            color: #00ff66;
            text-shadow: 0 0 10px #00ff66;
        }
        .nav-links .deposit-highlight {
            color: #ffcc00;
            border: 1px dashed #ffcc00;
            padding: 6px 12px;
            border-radius: 6px;
        }
        .nav-links .deposit-highlight:hover {
            background: #ffcc00;
            color: #000;
            box-shadow: 0 0 10px #ffcc00;
        }
        .nav-wallet-status {
            background: #222230;
            padding: 8px 16px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            color: #fff;
            font-size: 14px;
            border: 1px solid #333;
        }
        .nav-wallet-status strong {
            color: #ffcc00;
            margin-left: 6px;
        }
        .live-indicator {
            width: 8px;
            height: 8px;
            background: #00ff66;
            border-radius: 50%;
            margin-right: 8px;
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0% { transform: scale(0.9); opacity: 0.6; }
            50% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(0.9); opacity: 0.6; }
        }

        /* Homepage Hero & Content Welcome Section */
        .hero-section {
            max-width: 800px;
            margin: 60px auto;
            text-align: center;
            padding: 20px;
        }
        .hero-section h2 {
            font-size: 42px;
            color: #00ff66;
            margin-bottom: 10px;
        }
        .hero-section p {
            color: #aaa;
            font-size: 18px;
            line-height: 1.6;
        }
        .cta-btn {
            background: #00ff66;
            color: #000;
            padding: 15px 40px;
            font-size: 18px;
            font-weight: bold;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin-top: 20px;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(0, 255, 102, 0.3);
        }
        .cta-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 25px #00ff66;
        }
    </style>
</head>
<body>

<!-- 1. Gaming Navigation Bar Component Header (With Rock-Paper Included) -->
<nav class="gaming-navbar">
    <div class="nav-logo">
        <a href="index.html">🎮 PLAYWITHALINA <span class="pro-tag">PRO</span></a>
    </div>
    
    <div class="nav-links">
        <a href="games.html" class="nav-item">🔥 Mega Portal</a>
        <a href="snake.html" class="nav-item">🐍 Snake Cash</a>
        <a href="tictactoe.html" class="nav-item">❌ Tic-Tac-Toe</a>
        <a href="rps.html" class="nav-item">✊ Rock-Paper</a>
        <a href="deposit.html" class="nav-item deposit-highlight">💰 Add Funds</a>
    </div>

    <div class="nav-wallet-status">
        <div class="live-indicator"></div>
        <span>USD Balance: </span>
        <strong id="nav-wallet-display">$0.00</strong>
    </div>
</nav>

<!-- Main Homepage Hero Greeting -->
<div class="hero-section">
    <h2>Welcome to PlayWithAlina Arena</h2>
    <p>Play 1000+ top trending international HTML5 games. Challenge our advanced bots, win high target scores, and cash out real USD profits directly to your PayPal or Payoneer account!</p>
    <a href="games.html" class="cta-btn">Enter Gaming Arena</a>
</div>

<!-- 2. Main Live Firebase & App Download Registration Logic -->
<script type="module">
    import { initializeApp } from "https://gstatic.com";
    import { getFirestore, doc, onSnapshot } from "https://gstatic.com";
    import { getAuth, onAuthStateChanged } from "https://gstatic.com";

    // Aapka Real Firebase Configuration Linked Setup
    const firebaseConfig = {
        apiKey: "AIzaSyCjZk8A8tJvUf4YmIkAy-g3_5YqhvW-3Bc",
        authDomain: "://firebaseapp.com",
        projectId: "playwithalina-d7bb3",
        storageBucket: "playwithalina-d7bb3.firebasestorage.app",
        messagingSenderId: "18244211359",
        appId: "1:18244211359:web:d10be09d3e9fbb184c88aa"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    const auth = getAuth(app);

    // Watcher: Wallet Balance Live Update inside Header Navbar Component
    onAuthStateChanged(auth, user => {
        if (user) {
            onSnapshot(doc(db, 'users', user.uid), docSnap => {
                if (docSnap.exists()) {
                    let balance = docSnap.data().walletBalance || 0;
                    document.getElementById('nav-wallet-display').innerText = '$' + balance.toFixed(2);
                }
            });
        } else {
            console.log("No user signed in. Wallet showing default.");
        }
    });

    // 🚀 Smart App Installer Integration (Service Worker Registration)
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js')
                .then(reg => console.log('✅ PWA App ServiceWorker registered successfully!'))
                .catch(err => console.log('❌ ServiceWorker registration failed: ', err));
        });
    }
</script>
</body>
</html>
